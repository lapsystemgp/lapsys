DATABASE_URL="postgresql://postgres:postgres@localhost:5432/testly_db?schema=public"
JWT_SECRET="your-super-secure-jwt-secret-key"
LAB_STORAGE_DRIVER="local"
LAB_S3_BUCKET=""
LAB_S3_REGION=""
LAB_S3_ENDPOINT=""
LAB_S3_PUBLIC_BASE_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# Comma-separated list of allowed CORS origins (web app). Native mobile sends no Origin so is always allowed.
CORS_ORIGIN="http://localhost:3000"

# Firebase Admin SDK — paste the entire service-account JSON (from Firebase Console → Project Settings → Service Accounts)
# as a single-line string. Leave blank to disable push notifications (app still works, pushes are silently skipped).
FCM_SERVICE_ACCOUNT_JSON=""

# Google Gemini API key for the AI Health Assistant chatbot. Get one at https://aistudio.google.com/apikey.
# Leave blank to disable the assistant (the /chat endpoint returns 503 until set).
GEMINI_API_KEY=""

# SMTP for OTP verification emails. Works with any provider — no domain needed if
# you use single-sender verification (Brevo / SendGrid).
#   Brevo:    SMTP_HOST=smtp-relay.brevo.com  PORT=587  USER=<login>  PASS=<smtp key>
#   SendGrid: SMTP_HOST=smtp.sendgrid.net     PORT=587  USER=apikey   PASS=<api key>
#   Gmail:    SMTP_HOST=smtp.gmail.com        PORT=587  USER=you@gmail.com  PASS=<app password>
# Leave SMTP_HOST/USER/PASS blank in local dev — the 6-digit code is console.log'd instead.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Sender shown to users — must be your verified sender address (e.g. the email you confirmed in Brevo).
MAIL_FROM=""
