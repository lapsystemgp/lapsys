DATABASE_URL="postgresql://postgres:postgres@localhost:5432/testly_db?schema=public"
JWT_SECRET="your-super-secure-jwt-secret-key"
LAB_STORAGE_DRIVER="local"
LAB_S3_BUCKET=""
LAB_S3_REGION=""
LAB_S3_ENDPOINT=""
LAB_S3_PUBLIC_BASE_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# Comma-separated list of allowed CORS origins (web app). Native mobile sends no Origin so is always allowed.
CORS_ORIGIN="http://localhost:3000"

# Firebase Admin SDK — paste the entire service-account JSON (from Firebase Console → Project Settings → Service Accounts)
# as a single-line string. Leave blank to disable push notifications (app still works, pushes are silently skipped).
FCM_SERVICE_ACCOUNT_JSON=""

# Google Gemini API key for the AI Health Assistant chatbot. Get one at https://aistudio.google.com/apikey.
# Leave blank to disable the assistant (the /chat endpoint returns 503 until set).
GEMINI_API_KEY=""

# Resend email service for OTP verification. Get a key at https://resend.com.
# Leave blank in local dev — the 6-digit code will be console.log'd instead.
RESEND_API_KEY=""
# Sender address shown to users (must be a verified domain in Resend for production).
MAIL_FROM="onboarding@resend.dev"
