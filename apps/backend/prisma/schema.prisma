// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          Role     @default(Patient)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  patient_profile PatientProfile?
  lab_profile     LabProfile?
  status_events   BookingStatusEvent[]
  result_files    ResultFile[]         @relation("ResultFilesUploadedBy")
}

enum Role {
  Patient
  LabStaff
  Admin
}

enum LabOnboardingStatus {
  PendingReview
  Active
  Rejected
  Suspended
}

enum BookingType {
  LabVisit
  HomeCollection
}

enum BookingStatus {
  Pending
  Confirmed
  Rejected
  Cancelled
  Completed
}

enum PaymentMethod {
  Online
  CashHomeCollection
  CashLabVisit
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded
}

enum ResultStatus {
  Pending
  Uploaded
  Delivered
}

enum ReviewStatus {
  Pending
  Published
  Rejected
}

model PatientProfile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  full_name  String?
  phone      String?
  address    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User      @relation(fields: [user_id], references: [id])
  bookings Booking[]
  reviews  Review[]
}

model LabProfile {
  id                String              @id @default(uuid())
  user_id           String              @unique
  lab_name          String
  phone             String?
  address           String
  accreditation     String?
  turnaround_time   String?
  home_collection   Boolean             @default(false)
  onboarding_status LabOnboardingStatus @default(PendingReview)
  rating_average    Float?
  review_count      Int                 @default(0)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  user           User             @relation(fields: [user_id], references: [id])
  tests          LabTest[]
  schedule_slots LabScheduleSlot[]
  bookings       Booking[]
  reviews        Review[]
}

model LabTest {
  id               String   @id @default(uuid())
  lab_profile_id   String
  name             String
  category         String
  price_egp        Int
  description      String?
  preparation      String?
  turnaround_time  String?
  parameters_count Int?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  lab_profile LabProfile @relation(fields: [lab_profile_id], references: [id])
  bookings    Booking[]
}

model LabScheduleSlot {
  id             String   @id @default(uuid())
  lab_profile_id String
  starts_at      DateTime
  ends_at        DateTime
  capacity       Int      @default(1)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  lab_profile LabProfile @relation(fields: [lab_profile_id], references: [id])
  booking     Booking?

  @@index([lab_profile_id, starts_at])
}

model Booking {
  id                 String        @id @default(uuid())
  patient_profile_id String
  lab_profile_id     String
  lab_test_id        String
  booking_type       BookingType
  status             BookingStatus @default(Pending)
  scheduled_at       DateTime
  home_address       String?
  total_price_egp    Int
  payment_method         PaymentMethod  @default(Online)
  payment_status         PaymentStatus  @default(Pending)
  payment_reference      String?
  payment_paid_at        DateTime?
  payment_failed_at      DateTime?
  payment_failure_reason String?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  patient_profile PatientProfile     @relation(fields: [patient_profile_id], references: [id])
  lab_profile     LabProfile         @relation(fields: [lab_profile_id], references: [id])
  lab_test        LabTest            @relation(fields: [lab_test_id], references: [id])
  status_events   BookingStatusEvent[]
  result_file     ResultFile?
  result_summary  ResultSummary?
  result_panels   ResultPanel[]
  review          Review?
  schedule_slot_id String?           @unique
  schedule_slot   LabScheduleSlot?   @relation(fields: [schedule_slot_id], references: [id])

  @@index([lab_profile_id, scheduled_at])
  @@index([patient_profile_id, scheduled_at])
}

/// Canonical analyte for cross-lab trending (one patient-centered code, many raw names).
model CanonicalMarker {
  id           String   @id @default(uuid())
  code         String   @unique
  display_name String
  category     String?
  default_unit String?
  loinc_code   String?
  created_at   DateTime @default(now())

  aliases       MarkerAlias[]
  observations  ResultObservation[]

  @@index([category])
}

/// Maps normalized raw names from lab reports to a canonical marker.
model MarkerAlias {
  id                   String   @id @default(uuid())
  canonical_marker_id  String
  alias_normalized     String   @unique

  canonical_marker CanonicalMarker @relation(fields: [canonical_marker_id], references: [id], onDelete: Cascade)

  @@index([canonical_marker_id])
}

/// A logical panel (e.g. chemistry, thyroid) under one booking; holds structured observations.
model ResultPanel {
  id          String   @id @default(uuid())
  booking_id  String
  name        String?
  test_date   DateTime
  sort_order  Int      @default(0)

  booking       Booking             @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  observations ResultObservation[]

  @@index([booking_id])
  @@index([booking_id, test_date])
}

model ResultObservation {
  id                      String   @id @default(uuid())
  panel_id                String
  canonical_marker_id     String?
  raw_name                String
  value_numeric           Decimal? @db.Decimal(18, 6)
  value_text              String?
  unit                    String?
  ref_low                 Decimal? @db.Decimal(18, 6)
  ref_high                Decimal? @db.Decimal(18, 6)
  ref_text                String?
  value_in_canonical_unit Decimal? @db.Decimal(18, 6)
  comparable_unit         String?
  is_comparable           Boolean  @default(true)
  comparability_note      String?

  panel             ResultPanel      @relation(fields: [panel_id], references: [id], onDelete: Cascade)
  canonical_marker  CanonicalMarker? @relation(fields: [canonical_marker_id], references: [id], onDelete: SetNull)

  @@index([panel_id])
  @@index([canonical_marker_id])
}

model BookingStatusEvent {
  id           String        @id @default(uuid())
  booking_id   String
  status       BookingStatus
  note         String?
  actor_user_id String?
  created_at   DateTime      @default(now())

  booking    Booking @relation(fields: [booking_id], references: [id])
  actor_user User?   @relation(fields: [actor_user_id], references: [id])

  @@index([booking_id, created_at])
}

model ResultFile {
  id                String       @id @default(uuid())
  booking_id        String       @unique
  status            ResultStatus @default(Pending)
  file_name         String
  file_url          String
  mime_type         String
  size_bytes        Int
  uploaded_at       DateTime     @default(now())
  uploaded_by_user_id String?

  booking          Booking @relation(fields: [booking_id], references: [id])
  uploaded_by_user User?   @relation("ResultFilesUploadedBy", fields: [uploaded_by_user_id], references: [id])
}

model ResultSummary {
  id         String   @id @default(uuid())
  booking_id String   @unique
  summary    String
  highlights Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id])
}

model Review {
  id                 String       @id @default(uuid())
  booking_id         String       @unique
  patient_profile_id String
  lab_profile_id     String
  rating             Int
  comment            String?
  status             ReviewStatus @default(Pending)
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt

  booking         Booking        @relation(fields: [booking_id], references: [id])
  patient_profile PatientProfile @relation(fields: [patient_profile_id], references: [id])
  lab_profile     LabProfile     @relation(fields: [lab_profile_id], references: [id])
}

model FaqEntry {
  id         String   @id @default(uuid())
  question   String
  answer     String
  category   String?
  tags       String[]
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
